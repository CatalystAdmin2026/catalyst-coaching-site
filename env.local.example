SHEETS_ONBOARDING_GAS_URL=https://script.google.com/macros/s/AKfycbzo7bkzArWJH0ev-k6l5TmPA1pGUbpjYn_US4hQj4hrVw8qLiHLUxnmH5qC7zPG9YmA/exec


# ── Stripe Events — Google Sheets persistence ─────────────────
#
# STRIPE_EVENTS_GAS_URL
#   The /exec URL of the Google Apps Script web app created from
#   scripts/stripe-events-backend.gs. This script receives normalized
#   Stripe event data from the webhook and writes it to a "Stripe Events"
#   sheet tab. Also exposes doGet() so the Live Sheets tab can read it.
#
#   Setup:
#     1. Create a new Google Sheet: "Catalyst Coaching — Stripe Events"
#     2. Extensions → Apps Script → paste scripts/stripe-events-backend.gs
#     3. Deploy → New deployment → Web app → Execute as: Me → Access: Anyone
#     4. Copy the /exec URL and paste below
#     5. Add the same URL to Vercel: Settings → Environment Variables → STRIPE_EVENTS_GAS_URL
#
STRIPE_EVENTS_GAS_URL=


# ── Stripe — server-side only ────────────────────────────────
#
# NEVER use NEXT_PUBLIC_ prefix for Stripe keys.
# These must remain server-side only and never reach the browser.
#
# STRIPE_SECRET_KEY
#   Found in Stripe Dashboard → Developers → API Keys → Secret key
#   Use sk_test_... for development, sk_live_... for production.
#   Do NOT commit this value.
#
STRIPE_SECRET_KEY=


# STRIPE_WEBHOOK_SECRET
#   Found in Stripe Dashboard → Developers → Webhooks → [your endpoint] → Signing secret
#   Starts with whsec_...
#   For local testing: get a temporary secret from `stripe listen`
#     1. Install Stripe CLI: brew install stripe/stripe-cli/stripe
#     2. Run: stripe listen --forward-to localhost:3000/api/stripe/webhook
#     3. Copy the whsec_... value it prints and paste below
#   Do NOT commit this value.
#
STRIPE_WEBHOOK_SECRET=


# ── Calendly — server-side only ──────────────────────────────
#
# NEVER use NEXT_PUBLIC_ prefix for the Calendly token.
# These env vars are read only by /api/calendly/events (server-side).
#
# CALENDLY_PERSONAL_ACCESS_TOKEN
#   How to get it:
#     1. Log in to calendly.com
#     2. Go to Settings → Integrations → API & Webhooks
#     3. Under "Personal Access Tokens" click "Create new token"
#     4. Give it a name (e.g. "Catalyst Dashboard") and copy the token
#   Starts with "eyJ..." (a JWT).
#   Do NOT commit this value.
#
CALENDLY_PERSONAL_ACCESS_TOKEN=


# CALENDLY_USER_URI
#   The URI that identifies your Calendly account in the API.
#   Required to scope event queries to your account (not the whole org).
#
#   How to get it (after you have the token above):
#     Option A — curl from terminal:
#       curl -H "Authorization: Bearer YOUR_TOKEN_HERE" \
#            https://api.calendly.com/users/me
#       Copy the value of: resource.uri
#       Example: https://api.calendly.com/users/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
#
#     Option B — browser dev tools:
#       Open calendly.com, open DevTools → Network tab,
#       look for any request to api.calendly.com/users/me.
#
#   Do NOT commit this value.
#
CALENDLY_USER_URI=


# ─────────────────────────────────────────────────────────────
# Setup checklist:
#
# Google Sheets (Phase 1):
#   1. Copy this file to .env.local
#   2. Add doGet() to both GAS scripts (code above)
#   3. Redeploy both scripts
#   4. Restart dev server → /admin → Live Sheets tab
#
# Stripe Webhooks (Phase 2A — route + verification):
#   1. Add STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET to .env.local
#   2. Register endpoint in Stripe Dashboard:
#        Developers → Webhooks → Add endpoint
#        URL: https://www.catalystcoachingelite.com/api/stripe/webhook
#        Events: checkout.session.completed
#                customer.subscription.created
#                customer.subscription.updated
#                customer.subscription.deleted
#                invoice.paid
#                invoice.payment_failed
#   3. Restart dev server → check terminal logs for [Stripe Webhook] output
#   4. For local testing: stripe listen --forward-to localhost:3000/api/stripe/webhook
#
# Stripe Events → Google Sheets (Phase 2B — persistence):
#   1. Create Google Sheet: "Catalyst Coaching — Stripe Events"
#   2. Extensions → Apps Script → paste scripts/stripe-events-backend.gs → Deploy
#   3. Add STRIPE_EVENTS_GAS_URL to .env.local (URL from step 2)
#   4. Add STRIPE_EVENTS_GAS_URL to Vercel environment variables
#   5. Trigger a test webhook → check the sheet for the new row
#   6. Open /admin → Live Sheets — Stripe Events section should appear
#
# Calendly Integration (Phase 3):
#   1. Create personal access token at calendly.com → Settings → Integrations
#   2. Run: curl -H "Authorization: Bearer YOUR_TOKEN" \
#                https://api.calendly.com/users/me
#      Copy resource.uri → paste as CALENDLY_USER_URI
#   3. Add both values to .env.local and restart dev server
#   4. Add both to Vercel: Settings → Environment Variables
#   5. Open /admin → Calendly tab to verify events load
# ─────────────────────────────────────────────────────────────
