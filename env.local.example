# ─────────────────────────────────────────────────────────────
# Catalyst Coaching — local environment variables
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and never committed.
# ─────────────────────────────────────────────────────────────


# ── Google Apps Script — READ endpoints ──────────────────────
#
# These are the same web app URLs that receive your form POST submissions,
# but the doGet() handler below must be added to each script and the script
# must be redeployed before the Live Sheets tab will work.
#
# STEP 1 — Add doGet() to the Applications script
# Open: script.google.com → your Applications project → paste this function:
#
#   function doGet(e) {
#     try {
#       const ss   = SpreadsheetApp.getActiveSpreadsheet();
#       const tab  = ss.getSheets()[0]; // first sheet = applications log
#       const rows = tab.getDataRange().getValues();
#       if (rows.length < 2) return jsonOut({ ok: true, data: [] });
#       const headers = rows[0];
#       const data    = rows.slice(1).map(function(row) {
#         var obj = {};
#         headers.forEach(function(h, i) { obj[h] = row[i]; });
#         return obj;
#       });
#       return jsonOut({ ok: true, data: data });
#     } catch(err) {
#       return jsonOut({ ok: false, error: String(err) });
#     }
#   }
#
#   function jsonOut(obj) {
#     return ContentService
#       .createTextOutput(JSON.stringify(obj))
#       .setMimeType(ContentService.MimeType.JSON);
#   }
#
# Then: Deploy → Manage deployments → create a new version → Deploy.
# Copy the new /exec URL below (or reuse the existing one if same deployment).

SHEETS_APPLICATIONS_GAS_URL=https://script.google.com/macros/s/AKfycbxf3VInd_v9ZJpIedP0fImdFedh-1xi9oBPA7dRKMATwLupMLdy41OmrRFwnIzYVqXd5w/exec


